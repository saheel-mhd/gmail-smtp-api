generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  active
  disabled
}

enum UserRole {
  owner
  admin
  readonly
}

enum SenderStatus {
  active
  disabled
  needs_attention
}

enum ApiKeyStatus {
  active
  revoked
}

enum TemplateStatus {
  active
  disabled
}

enum DomainStatus {
  pending
  verified
  failed
}

enum MessageStatus {
  queued
  sending
  sent
  failed
}

enum ActorType {
  user
  api_key
  system
}

enum CampaignStatus {
  draft
  running
  paused
  completed
  failed
  cancelled
}

enum CampaignRecipientStatus {
  pending
  queued
  sending
  sent
  failed
  skipped
}

enum CampaignSenderType {
  gmail
  domain
}

model Tenant {
  id                 String        @id @default(cuid())
  name               String
  plan               String        @default("free")
  status             TenantStatus  @default(active)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  users              User[]
  smtpAccounts       SmtpAccount[]
  domainSenders      DomainSender[]
  apiKeys            ApiKey[]
  templates          Template[]
  messages           Message[]
  auditLogs          AuditLog[]
  companies          Company[]
  domains            Domain[]
  campaigns          Campaign[]
  dailySentCount     Int           @default(0)
  dailyCountResetAt  DateTime?
}

model User {
  id               String    @id @default(cuid())
  tenantId         String
  email            String
  passwordHash     String
  role             UserRole  @default(admin)
  mfaEnabled       Boolean   @default(false)
  mfaSecretEnc     String?
  mfaSecretIv      String?
  mfaSecretTag     String?
  lastLogin        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company          Company?
  domains          Domain[]
  campaigns        Campaign[]

  @@unique([tenantId, email])
}

model Domain {
  id                String       @id @default(cuid())
  tenantId          String
  userId            String
  domain            String
  status            DomainStatus @default(pending)
  verificationToken String
  txtHost           String
  txtValue          String
  spfHost           String
  spfValue          String
  cnameHost         String
  cnameValue        String
  mxHost            String
  mxPriority        Int          @default(10)
  smtpHost          String?
  smtpPort          Int          @default(587)
  smtpSecure        Boolean      @default(false)
  verifiedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  senders DomainSender[]

  @@index([tenantId])
  @@unique([userId, domain])
}

model Company {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String   @unique
  name      String
  service   String
  phone     String
  email     String
  address   String
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SmtpAccount {
  id                     String       @id @default(cuid())
  tenantId               String
  label                  String
  gmailAddress           String
  encryptedAppPassword   String
  iv                     String
  authTag                String
  keyVersion             String
  status                 SenderStatus @default(active)
  perMinuteLimit         Int          @default(60)
  perDayLimit            Int          @default(2000)
  sentTodayCount         Int          @default(0)
  sentTodayResetAt       DateTime?
  lastSuccessAt          DateTime?
  lastErrorAt            DateTime?
  errorStreak            Int          @default(0)
  healthScore            Int          @default(100)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  tenant                 Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions            ApiKeyPermission[]
  messages               Message[]
  campaigns              Campaign[]

  @@index([tenantId])
  @@unique([tenantId, gmailAddress])
}

model DomainSender {
  id               String       @id @default(cuid())
  tenantId         String
  domainId         String
  label            String
  emailAddress     String
  username         String
  encryptedPassword String
  iv               String
  authTag          String
  keyVersion       String
  status           SenderStatus @default(active)
  perDayLimit       Int          @default(2000)
  sentTodayCount    Int          @default(0)
  sentTodayResetAt  DateTime?
  lastSuccessAt     DateTime?
  lastErrorAt       DateTime?
  errorStreak       Int          @default(0)
  healthScore       Int          @default(100)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  messages Message[]
  permissions ApiKeyDomainPermission[]
  campaigns Campaign[]

  @@index([tenantId])
  @@unique([tenantId, emailAddress])
}

model ApiKey {
  id                 String       @id @default(cuid())
  tenantId           String
  name               String
  keyHash            String
  prefix             String
  status             ApiKeyStatus @default(active)
  createdAt          DateTime     @default(now())
  revokedAt          DateTime?
  rateLimitPerMinute Int          @default(120)
  allowedIps         Json?
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions        ApiKeyPermission[]
  domainPermissions  ApiKeyDomainPermission[]
  messages           Message[]

  @@index([tenantId, status])
}

model ApiKeyPermission {
  apiKeyId      String
  smtpAccountId String
  apiKey        ApiKey      @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  smtpAccount   SmtpAccount @relation(fields: [smtpAccountId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, smtpAccountId])
}

model ApiKeyDomainPermission {
  apiKeyId       String
  domainSenderId String
  apiKey         ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  domainSender   DomainSender @relation(fields: [domainSenderId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, domainSenderId])
}

model Message {
  id             String        @id @default(cuid())
  tenantId       String
  apiKeyId       String?
  smtpAccountId  String?
  domainSenderId String?
  campaignRecipientId String?
  idempotencyKey String
  to             Json
  cc             Json
  bcc            Json
  subject        String
  text           String?
  html           String?
  fromName       String?
  replyTo        String?
  headers        Json?
  status         MessageStatus @default(queued)
  attempts       Int           @default(0)
  lastError      String?
  createdAt      DateTime      @default(now())
  queuedAt       DateTime      @default(now())
  sentAt         DateTime?
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKey         ApiKey?       @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)
  smtpAccount    SmtpAccount?  @relation(fields: [smtpAccountId], references: [id], onDelete: Restrict)
  domainSender   DomainSender? @relation(fields: [domainSenderId], references: [id], onDelete: Restrict)
  campaignRecipient CampaignRecipient? @relation(fields: [campaignRecipientId], references: [id], onDelete: SetNull)

  @@unique([apiKeyId, idempotencyKey])
  @@index([tenantId, createdAt])
  @@index([status, createdAt])
}

model Template {
  id        String         @id @default(cuid())
  tenantId  String
  name      String
  subject   String
  html      String
  text      String?
  status    TemplateStatus @default(active)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([tenantId])
  @@unique([tenantId, name])
}

model Campaign {
  id                     String             @id @default(cuid())
  tenantId               String
  userId                 String
  name                   String
  status                 CampaignStatus     @default(draft)
  senderType             CampaignSenderType
  smtpAccountId          String?
  domainSenderId         String?
  templateId             String?
  subject                String?
  html                   String?
  text                   String?
  fromName               String?
  replyTo                String?
  headers                Json?
  perMinuteLimit         Int?
  perMessageDelaySeconds Int          @default(0)
  warmupEnabled          Boolean            @default(false)
  warmupStartPerMinute   Int                @default(20)
  warmupStep             Int                @default(10)
  warmupIntervalMinutes  Int                @default(60)
  warmupMaxPerMinute     Int                @default(200)
  trackOpens             Boolean            @default(true)
  trackClicks            Boolean            @default(true)
  trackReplies           Boolean            @default(false)
  totalRecipients        Int                @default(0)
  queuedCount            Int                @default(0)
  sentCount              Int                @default(0)
  failedCount            Int                @default(0)
  openedCount            Int                @default(0)
  clickedCount           Int                @default(0)
  repliedCount           Int                @default(0)
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  smtpAccount   SmtpAccount? @relation(fields: [smtpAccountId], references: [id], onDelete: SetNull)
  domainSender  DomainSender? @relation(fields: [domainSenderId], references: [id], onDelete: SetNull)
  template      Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients    CampaignRecipient[]

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
}

model CampaignRecipient {
  id            String                  @id @default(cuid())
  campaignId    String
  email         String
  name          String?
  status        CampaignRecipientStatus @default(pending)
  attempts      Int                     @default(0)
  lastError     String?
  sentAt        DateTime?
  openedAt      DateTime?
  openCount     Int                     @default(0)
  clickedAt     DateTime?
  clickCount    Int                     @default(0)
  clickedUrl    String?
  repliedAt     DateTime?
  replyCount    Int                     @default(0)
  messageId     String?
  variables     Json?
  trackingToken String                  @unique
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  campaign      Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([campaignId, status])
  @@unique([campaignId, email])
}

model AuditLog {
  id         String    @id @default(cuid())
  tenantId   String
  actorType  ActorType
  actorId    String
  action     String
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}
